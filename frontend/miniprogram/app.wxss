page { background: #f7f8fa; color: #17212b; font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif; font-size: 28rpx; }
view, text, button, input, textarea, picker { box-sizing: border-box; }
.page { min-height: 100vh; padding: 48rpx 40rpx 64rpx; }
.eyebrow { color: #0d7c66; font-size: 24rpx; font-weight: 600; letter-spacing: 0; }
.title { display: block; margin-top: 16rpx; color: #101820; font-size: 56rpx; font-weight: 700; line-height: 1.2; }
.muted { color: #68747d; line-height: 1.65; }
.section-title { display: block; margin: 48rpx 0 24rpx; font-size: 32rpx; font-weight: 700; }
.panel { margin-top: 32rpx; padding: 32rpx; background: #fff; border: 1rpx solid #e3e7e9; border-radius: 8rpx; }
.button-primary { width: 100%; margin: 32rpx 0 0; padding: 0; height: 96rpx; background: #0d7c66; border-radius: 8rpx; color: #fff; font-size: 30rpx; line-height: 96rpx; }
.button-secondary { width: 100%; margin: 20rpx 0 0; padding: 0; height: 88rpx; background: #edf5f2; border-radius: 8rpx; color: #0d7c66; font-size: 28rpx; line-height: 88rpx; }
button::after { border: 0; }
.link { color: #0d7c66; }
.error { margin-top: 24rpx; padding: 24rpx; background: #fff2f0; border-left: 6rpx solid #d94f45; color: #a53b34; line-height: 1.5; }
.loading { padding: 80rpx 0; text-align: center; color: #68747d; }
