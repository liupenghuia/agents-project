<view class="chat-page">
  <view wx:if="{{loading}}" class="chat-state">正在读取消息…</view>

  <block wx:elif="{{conversation}}">
    <view class="chat-peer">
      <text class="chat-peer-name">{{conversation.peer.displayName || '沟通'}}</text>
      <text class="chat-peer-status">
        {{conversation.status === 'active' ? '会话进行中' : conversation.status === 'ended' ? '会话已结束' : '会话已阻止'}}
      </text>
    </view>

    <scroll-view
      class="chat-scroll"
      scroll-y
      scroll-into-view="{{scrollIntoView}}"
      scroll-with-animation
    >
      <view wx:if="{{!messages.length}}" class="chat-empty">打个招呼开始沟通吧</view>
      <view
        wx:for="{{messages}}"
        wx:key="id"
        id="m-{{item.id}}"
        class="bubble-row {{item.mine ? 'is-mine' : 'is-theirs'}}"
      >
        <view class="bubble {{item.mine ? 'mine' : 'theirs'}}">
          <text class="bubble-text">{{item.body}}</text>
          <text class="bubble-time">{{item.createdAt}}</text>
        </view>
      </view>
      <view id="chat-bottom" class="chat-bottom-spacer"></view>
    </scroll-view>

    <view wx:if="{{conversation.status === 'active'}}" class="composer safe-bottom">
      <input
        class="composer-input"
        value="{{draft}}"
        bindinput="input"
        maxlength="1000"
        confirm-type="send"
        bindconfirm="send"
        placeholder="输入消息"
        placeholder-class="composer-ph"
      />
      <button
        class="composer-send"
        loading="{{sending}}"
        disabled="{{sending || !draft}}"
        bindtap="send"
      >发送</button>
    </view>
    <view wx:else class="chat-closed safe-bottom">
      会话已{{conversation.status === 'ended' ? '结束' : '阻止'}}，无法继续发送
    </view>

    <view
      wx:if="{{conversation.status === 'active'}}"
      class="chat-more"
      bindtap="end"
    >结束会话</view>
  </block>

  <view wx:if="{{error}}" class="error">
    <text>{{error}}</text>
    <button class="button-secondary" bindtap="retry">重试</button>
  </view>
</view>
