.message-list { display: flex; flex-direction: column; gap: 16rpx; margin: 24rpx 0; min-height: 420rpx; }
.bubble { max-width: 78%; padding: 18rpx 22rpx; border-radius: 16rpx; font-size: 28rpx; }
.bubble.mine { align-self: flex-end; background: #0d7c66; color: #fff; }
.bubble.theirs { align-self: flex-start; background: #fff; border: 1rpx solid #d9e6e2; color: #17332d; }
.time { display: block; margin-top: 8rpx; opacity: 0.7; font-size: 20rpx; }
.composer { display: flex; gap: 12rpx; margin-top: 16rpx; }
.composer input { flex: 1; height: 76rpx; padding: 0 20rpx; border: 1rpx solid #d5dfdb; background: #fff; }
.composer button { margin: 0; height: 76rpx; line-height: 76rpx; padding: 0 28rpx; background: #0d7c66; color: #fff; }
