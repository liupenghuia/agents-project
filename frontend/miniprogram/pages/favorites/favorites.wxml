<view class="page">
  <view class="eyebrow">我的收藏</view><text class="title">已收藏信息</text>
  <view wx:if="{{loading}}" class="loading">正在读取收藏...</view>
  <view wx:elif="{{!items.length && !error}}" class="panel empty">暂无收藏</view>
  <view wx:for="{{items}}" wx:key="id" class="action-card" data-id="{{item.id}}" bindtap="open">
    <text class="action-title">{{item.jobType || item.jobTypeName}}</text>
    <text class="muted">{{item.salaryRange || item.expectedSalary}} · {{item.status === 'published' ? '可查看' : '已失效'}}</text>
    <text class="published">发布时间：{{item.publishedAt}}</text>
    <button class="remove-button" data-id="{{item.id}}" loading="{{removingId === item.id}}" disabled="{{!!removingId}}" catchtap="remove">取消收藏</button>
  </view>
  <view wx:if="{{error}}" class="error"><text>{{error}}</text><button class="button-secondary" bindtap="retry">重试</button></view>
  <view class="subnav">
    <button class="button-secondary" bindtap="openMarket">回地图</button>
    <button class="button-secondary" bindtap="openMyCenter">回我的</button>
  </view>
</view>
