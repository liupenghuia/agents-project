<view class="page"><view class="eyebrow">我的收藏</view><text class="title">已收藏信息</text><view wx:if="{{!items.length}}" class="panel empty">暂无收藏</view><button wx:for="{{items}}" wx:key="id" class="action-card" data-id="{{item.id}}" bindtap="remove"><text class="action-title">{{item.jobType || item.jobTypeName}}</text><text class="muted">{{item.salaryRange || item.expectedSalary}} · {{item.status === 'published' ? '可查看' : '已失效'}}</text><text class="published">发布时间：{{item.publishedAt}}</text><text class="published">点击取消收藏</text></button><view wx:if="{{error}}" class="error">{{error}}</view></view>
