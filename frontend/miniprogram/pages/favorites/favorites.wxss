.page {
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

.empty {
  margin-top: 24rpx;
  text-align: center;
  color: var(--color-text-muted);
}

.action-card {
  margin-top: 14rpx;
  padding: 28rpx;
}

.action-title {
  display: block;
  color: var(--color-text);
  font-size: 30rpx;
  font-weight: 700;
}

.published {
  display: block;
  margin-top: 10rpx;
  color: var(--color-text-muted);
  font-size: 22rpx;
}

.remove-button {
  margin: 22rpx 0 0;
  padding: 0 24rpx;
  height: 64rpx;
  border: 1rpx solid #e8c5bf;
  border-radius: 999rpx;
  background: #fff;
  color: #a33f37;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 64rpx;
}

.subnav {
  display: flex;
  gap: 16rpx;
  margin-top: 32rpx;
}

.subnav .button-secondary {
  flex: 1;
  margin-top: 0;
}
