.intro {
  display: block;
  margin-top: 20rpx;
  font-size: 27rpx;
}

.role-grid {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.role-card {
  flex: 1;
  min-height: 300rpx;
  padding: 32rpx 28rpx;
  text-align: left;
  border: 0;
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-md);
}

.recruiter {
  background: linear-gradient(160deg, #e8f7f1 0%, #d4efe6 100%);
  color: #0a5c4c;
}

.applicant {
  background: linear-gradient(160deg, #fff4ea 0%, #ffe4cc 100%);
  color: #9a4f1f;
}

.role-mark {
  display: grid;
  width: 72rpx;
  height: 72rpx;
  place-items: center;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.72);
  font-size: 34rpx;
  font-weight: 800;
}

.role-title {
  display: block;
  margin-top: 48rpx;
  font-size: 34rpx;
  font-weight: 700;
}

.role-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  opacity: 0.78;
  line-height: 1.45;
}

.identity-section {
  margin-top: 48rpx;
}

.section-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-row .section-title {
  margin: 0;
}

.identity-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 14rpx;
  padding: 26rpx 28rpx;
  background: #fff;
  border: 1rpx solid var(--color-border-soft);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}

.identity-name,
.identity-id {
  display: block;
}

.identity-name {
  font-weight: 600;
  font-size: 28rpx;
}

.identity-id {
  margin-top: 6rpx;
  color: var(--color-text-muted);
  font-size: 22rpx;
}

.status {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.status-pending_review {
  background: #fff5d6;
  color: #8e6811;
}

.status-approved {
  background: #e6f6ee;
  color: #187049;
}

.status-changes_requested {
  background: #fff0ee;
  color: #a53b34;
}

.approved-section {
  margin-top: 36rpx;
}

.signed-in {
  display: block;
  color: #187049;
  font-size: 24rpx;
  font-weight: 600;
}

.entry-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  margin-top: 16rpx;
  padding: 30rpx 28rpx;
  background: linear-gradient(135deg, #e9f7f1, #dff3ea);
  border: 1rpx solid #c9e7dd;
  border-radius: var(--radius-lg);
  color: #0a5c4c;
  text-align: left;
  box-shadow: var(--shadow-sm);
}

.entry-card--applicant {
  background: linear-gradient(135deg, #fff4ea, #ffe8d4);
  border-color: #f0d2b4;
  color: #8a4b1c;
}

.entry-card--applicant .entry-desc {
  color: #a66a3a;
}

.entry-card--recruiter {
  background: linear-gradient(135deg, #e9f7f1, #dff3ea);
  border-color: #c9e7dd;
  color: #0a5c4c;
}

.entry-title,
.entry-desc {
  display: block;
}

.entry-title {
  font-size: 32rpx;
  font-weight: 700;
}

.entry-desc {
  margin-top: 8rpx;
  color: #4c8175;
  font-size: 23rpx;
}

.entry-arrow {
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.75);
  font-size: 24rpx;
  font-weight: 700;
}

.other-role {
  margin-top: 20rpx;
}
