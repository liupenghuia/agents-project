.intro { display: block; margin-top: 24rpx; }
.role-grid { display: flex; gap: 20rpx; margin-top: 48rpx; }
.role-card { flex: 1; min-height: 280rpx; padding: 32rpx 24rpx; text-align: left; border: 0; border-radius: 8rpx; }
.recruiter { background: #e9f4f0; color: #0d5e50; }
.applicant { background: #fff0e4; color: #a65e2d; }
.role-mark { display: block; font-size: 56rpx; font-weight: 700; }
.role-title { display: block; margin-top: 42rpx; font-size: 34rpx; font-weight: 700; }
.role-desc { display: block; margin-top: 12rpx; font-size: 24rpx; opacity: .8; }
.identity-section { margin-top: 52rpx; }
.section-row { display: flex; align-items: center; justify-content: space-between; }
.section-row .section-title { margin: 0; }
.identity-row { display: flex; align-items: center; justify-content: space-between; margin-top: 16rpx; padding: 24rpx; background: #fff; border: 1rpx solid #e3e7e9; border-radius: 8rpx; }
.identity-name, .identity-id { display: block; }
.identity-name { font-weight: 600; }
.identity-id { margin-top: 8rpx; color: #8a949b; font-size: 22rpx; }
.status { padding: 10rpx 16rpx; border-radius: 4rpx; font-size: 22rpx; }
.status-pending_review { background: #fff5d6; color: #8e6811; }
.status-approved { background: #e6f6ee; color: #187049; }
.status-changes_requested { background: #fff0ee; color: #a53b34; }
