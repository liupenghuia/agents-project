<view class="page detail-page">
  <view wx:if="{{loading}}" class="loading">正在读取详情...</view>
  <view wx:elif="{{item}}" class="detail-body">
    <view class="detail-intro">
      <text class="eyebrow">{{role === 'applicant' ? '招聘信息' : '求职信息'}}</text>
      <text class="title">{{item.jobType || item.jobTypeName}}</text>
      <text class="detail-pay">{{item.salaryLabel || item.salaryRange || item.expectedSalary || '面议'}}</text>
      <text class="published">发布时间：{{item.publishedAtLabel || item.publishedAt}}</text>
    </view>

    <view class="info-section">
      <view class="info-row"><text>薪资</text><text>{{item.salaryLabel || item.salaryRange || item.expectedSalary || '面议'}}</text></view>
      <view class="info-row"><text>方式</text><text>{{item.settlementMethod || item.workMethod || '—'}}</text></view>
      <view class="info-row"><text>位置</text><text>{{item.locationText || '位置待完善'}}</text></view>
      <view wx:if="{{item.preferredWorkScope}}" class="info-row"><text>工作范围</text><text>{{item.preferredWorkScope}}</text></view>
    </view>

    <scroll-view wx:if="{{item.images.length}}" class="detail-images" scroll-x>
      <image wx:for="{{item.images}}" wx:key="id" src="{{item.url}}" mode="aspectFill" />
    </scroll-view>

    <view class="contact-box">
      <view>
        <text class="contact-label">{{item.contactName || '联系方式'}}</text>
        <text class="contact-phone">{{item.contactPhone || '暂未公开'}}</text>
      </view>
      <button wx:if="{{item.contactPhone}}" class="contact-call" bindtap="call">拨打电话</button>
    </view>
  </view>

  <view wx:if="{{error}}" class="error">
    <text>{{error}}</text>
    <button class="button-secondary" bindtap="retry">重试</button>
  </view>

  <!-- Sticky primary actions: one main CTA + favorite + more -->
  <view wx:if="{{item && !reporting}}" class="detail-bar safe-bottom">
    <view
      class="detail-bar-side {{item.isFavorited ? 'is-on' : ''}}"
      bindtap="favorite"
    >{{item.isFavorited ? '已收藏' : '收藏'}}</view>
    <button
      class="detail-bar-primary"
      loading="{{actionLoading}}"
      disabled="{{actionLoading}}"
      bindtap="primaryAction"
    >{{role === 'applicant' ? '表达兴趣' : '聊一聊'}}</button>
    <view class="detail-bar-side" bindtap="openMore">更多</view>
  </view>

  <view wx:if="{{reporting}}" class="report-mask" bindtap="cancelReport"></view>
  <view wx:if="{{reporting}}" class="report-sheet">
    <text class="report-title">举报原因</text>
    <textarea
      value="{{reportReason}}"
      bindinput="inputReport"
      placeholder="请描述问题"
      maxlength="1000"
    />
    <view class="report-actions">
      <button bindtap="cancelReport">取消</button>
      <button class="report-submit" loading="{{actionLoading}}" bindtap="submitReport">提交举报</button>
    </view>
  </view>
</view>
