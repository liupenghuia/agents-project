.detail-page {
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

.detail-body {
  padding-bottom: 24rpx;
}

.detail-intro {
  padding: 8rpx 0 28rpx;
}

.detail-intro .title {
  font-size: 44rpx;
}

.detail-pay {
  display: block;
  margin-top: 14rpx;
  color: #e85d04;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.3;
}

.published {
  display: block;
  margin-top: 12rpx;
  color: var(--color-text-muted);
  font-size: 23rpx;
}

.info-section {
  margin-top: 8rpx;
  padding: 8rpx 28rpx;
  background: #fff;
  border: 1rpx solid var(--color-border-soft);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}

.info-row {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  padding: 26rpx 0;
  border-bottom: 1rpx solid var(--color-border-soft);
  color: var(--color-text-secondary);
  font-size: 26rpx;
}

.info-row:last-child {
  border-bottom: 0;
}

.info-row text:last-child {
  color: var(--color-text);
  font-weight: 600;
  text-align: right;
  max-width: 62%;
}

.detail-images {
  width: 100%;
  margin-top: 24rpx;
  white-space: nowrap;
}

.detail-images image {
  display: inline-block;
  width: 280rpx;
  height: 200rpx;
  margin-right: 14rpx;
  border-radius: var(--radius-md);
  background: #e8efec;
}

.contact-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 24rpx;
  padding: 28rpx;
  background: linear-gradient(135deg, #e9f7f1, #e0f3eb);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}

.contact-label {
  display: block;
  color: var(--color-text-muted);
  font-size: 23rpx;
}

.contact-phone {
  display: block;
  margin-top: 8rpx;
  color: var(--color-text);
  font-size: 32rpx;
  font-weight: 700;
}

.contact-call {
  flex-shrink: 0;
  margin: 0;
  padding: 0 28rpx;
  height: 72rpx;
  border-radius: 999rpx;
  background: #fff;
  color: var(--color-primary-deep);
  font-size: 24rpx;
  font-weight: 600;
  line-height: 72rpx;
  box-shadow: var(--shadow-sm);
}

/* —— Sticky bottom bar —— */
.detail-bar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 30;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.98);
  border-top: 1rpx solid var(--color-border-soft);
  box-shadow: 0 -8rpx 28rpx rgba(20, 40, 34, 0.06);
}

.detail-bar-side {
  flex-shrink: 0;
  min-width: 112rpx;
  height: 88rpx;
  padding: 0 12rpx;
  color: var(--color-text-secondary);
  font-size: 26rpx;
  font-weight: 600;
  line-height: 88rpx;
  text-align: center;
}

.detail-bar-side.is-on {
  color: var(--color-primary);
}

.detail-bar-primary {
  flex: 1;
  margin: 0 !important;
  height: 88rpx !important;
  padding: 0 !important;
  border-radius: 999rpx !important;
  background: linear-gradient(135deg, #0e8a70, #0c7a63) !important;
  color: #fff !important;
  font-size: 30rpx !important;
  font-weight: 700 !important;
  line-height: 88rpx !important;
  box-shadow: 0 10rpx 24rpx rgba(12, 122, 99, 0.28);
}

.detail-bar-primary[disabled] {
  opacity: 0.7;
}

/* —— Report sheet —— */
.report-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 40;
  background: rgba(0, 0, 0, 0.4);
}

.report-sheet {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 41;
  padding: 36rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  background: #fff;
  box-shadow: var(--shadow-lg);
}

.report-title {
  display: block;
  margin-bottom: 18rpx;
  font-size: 32rpx;
  font-weight: 700;
}

.report-sheet textarea {
  width: 100%;
  min-height: 180rpx;
  padding: 20rpx;
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-md);
  background: #f7faf9;
}

.report-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.report-actions button {
  flex: 1;
  margin: 0;
  height: 80rpx;
  border-radius: 999rpx;
  background: #f3f5f4;
  color: var(--color-text);
  font-size: 28rpx;
  font-weight: 600;
  line-height: 80rpx;
}

.report-actions .report-submit {
  background: linear-gradient(135deg, #0e8a70, #0c7a63);
  color: #fff;
}
