.detail-page { padding-bottom: 80rpx; }
.detail-intro { padding: 24rpx 0 32rpx; border-bottom: 1rpx solid #e3e7e9; }
.detail-intro .title { font-size: 48rpx; }
.info-section { margin-top: 24rpx; padding: 4rpx 24rpx; background: #fff; border: 1rpx solid #e3e7e9; }
.info-row { display: flex; justify-content: space-between; gap: 24rpx; padding: 24rpx 0; border-bottom: 1rpx solid #edf0f1; color: #45515a; }
.info-row:last-child { border-bottom: 0; }
.info-row text:last-child { color: #17212b; text-align: right; }
.detail-images { width: 100%; margin-top: 24rpx; white-space: nowrap; }
.detail-images image { display: inline-block; width: 270rpx; height: 200rpx; margin-right: 12rpx; background: #e8efec; }
.contact-box { display: flex; align-items: center; justify-content: space-between; gap: 20rpx; margin-top: 24rpx; padding: 24rpx; background: #edf5f2; }
.contact-label { display: block; color: #75817d; font-size: 23rpx; }
.contact-phone { display: block; margin-top: 8rpx; color: #17332d; font-size: 30rpx; font-weight: 700; }
.contact-box button, .primary-actions button, .report-sheet button { margin: 0; padding: 0 22rpx; height: 68rpx; background: #fff; color: #0d7c66; font-size: 24rpx; line-height: 68rpx; }
.primary-actions { display: flex; gap: 12rpx; margin-top: 24rpx; }
.primary-actions button { flex: 1; border: 1rpx solid #d5dfdb; }
.primary-actions .favorite, .report-sheet .favorite { background: #0d7c66; color: #fff; }
.report-sheet { position: fixed; right: 0; bottom: 0; left: 0; z-index: 20; padding: 32rpx; background: #fff; box-shadow: 0 -12rpx 48rpx #17332d2b; }
.report-title { display: block; margin-bottom: 18rpx; font-size: 32rpx; font-weight: 700; }
.report-sheet textarea { width: 100%; min-height: 180rpx; padding: 20rpx; border: 1rpx solid #d5dfdb; background: #f8faf9; }
.report-sheet > view { display: flex; gap: 16rpx; margin-top: 20rpx; }
.report-sheet > view button { flex: 1; }
