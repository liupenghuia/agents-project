<view class="market-page market-page--list">
  <view class="top-bar">
    <view class="search-bar">
      <text class="search-icon">⌕</text>
      <input
        class="search-input"
        value="{{keyword}}"
        bindinput="input"
        confirm-type="search"
        bindconfirm="search"
        placeholder="搜索工种、职位"
        placeholder-class="search-ph"
      />
      <text wx:if="{{keyword}}" class="search-clear" bindtap="clearKeyword">清除</text>
      <view class="search-submit" bindtap="search">搜索</view>
    </view>
    <view
      class="filter-btn {{activeFilterSummary ? 'on' : ''}}"
      bindtap="openFilters"
    >筛选</view>
  </view>

  <view wx:if="{{activeFilterSummary || totalCount !== null}}" class="result-bar">
    <text wx:if="{{totalCount !== null}}" class="result-count">共 {{totalCount}} 条</text>
    <text wx:if="{{activeFilterSummary}}" class="result-filters">{{activeFilterSummary}}</text>
    <text wx:if="{{activeFilterSummary}}" class="result-save" bindtap="saveCurrentFilters">保存条件</text>
  </view>

  <view class="list-view">
    <view wx:if="{{loading}}" class="state-tip">正在加载...</view>
    <view wx:elif="{{!items.length}}" class="state-empty">
      <text class="state-empty-title">暂无相关信息</text>
      <text class="state-empty-desc">试试换个关键词，或调整筛选条件</text>
    </view>
    <block wx:else>
      <view
        wx:for="{{items}}"
        wx:key="id"
        class="job-card"
        data-id="{{item.id}}"
        bindtap="open"
      >
        <image
          class="job-cover"
          src="{{item.coverImage || ''}}"
          mode="aspectFill"
          wx:if="{{item.coverImage}}"
        />
        <view wx:else class="job-cover job-cover--placeholder">职</view>
        <view class="job-body">
          <view class="job-top">
            <text class="job-title">{{role === 'applicant' ? item.jobType : item.jobTypeName}}</text>
            <text class="job-pay">{{item.salaryLabel || (role === 'applicant' ? item.salaryRange : item.expectedSalary)}}</text>
          </view>
          <text class="job-loc">{{item.locationText || '位置待完善'}}</text>
          <view class="job-bottom">
            <text wx:if="{{item.matchReasons.length}}" class="job-tag">{{item.matchReasons[0]}}</text>
            <text class="job-time">{{item.publishedAtLabel || item.publishedAt}}</text>
          </view>
        </view>
      </view>
      <view wx:if="{{loadingMore}}" class="state-tip">正在加载更多...</view>
      <view wx:elif="{{!nextCursor}}" class="state-tip">已显示全部</view>
    </block>
  </view>

  <view wx:if="{{error}}" class="error-bar">
    <text>{{error}}</text>
    <text class="error-retry" bindtap="retry">重试</text>
  </view>

  <view wx:if="{{showFilters}}" class="filter-mask" bindtap="closeFilters"></view>
  <view wx:if="{{showFilters}}" class="filter-sheet">
    <view class="filter-head">
      <text class="filter-title">筛选</text>
      <text class="filter-close" bindtap="closeFilters">关闭</text>
    </view>
    <label class="f-label">工种
      <input data-field="jobType" value="{{draftFilters.jobType}}" bindinput="filterInput" placeholder="例如：服务员" />
    </label>
    <label class="f-label">薪资
      <input data-field="salaryRange" value="{{draftFilters.salaryRange}}" bindinput="filterInput" placeholder="例如：5K-8K" />
    </label>
    <label class="f-label">位置
      <input data-field="location" value="{{draftFilters.location}}" bindinput="filterInput" placeholder="区域关键词" />
    </label>
    <label class="f-label">发布时间起
      <input data-field="publishedFrom" value="{{draftFilters.publishedFrom}}" type="date" bindinput="filterInput" />
    </label>
    <label class="f-label">发布时间止
      <input data-field="publishedTo" value="{{draftFilters.publishedTo}}" type="date" bindinput="filterInput" />
    </label>
    <label class="f-label">工作方式
      <picker range="{{['月结','不定时长']}}" bindchange="pickWorkMethod">
        <view class="f-picker">{{draftFilters.workMethod === 'monthly_settlement' ? '月结' : draftFilters.workMethod === 'indefinite_duration' ? '不定时长' : '不限'}}</view>
      </picker>
    </label>
    <view wx:if="{{savedFilters.length}}" class="saved-block">
      <text class="saved-title">已保存筛选</text>
      <view wx:for="{{savedFilters}}" wx:key="savedAt" class="saved-row">
        <view class="saved-btn" data-source="saved" data-index="{{index}}" bindtap="applySavedFilter">应用</view>
        <view class="saved-btn" data-index="{{index}}" bindtap="deleteSavedFilter">删除</view>
      </view>
    </view>
    <view wx:if="{{recentSearches.length}}" class="saved-block">
      <text class="saved-title">最近搜索</text>
      <view wx:for="{{recentSearches}}" wx:key="savedAt" class="saved-row">
        <view class="saved-btn" data-source="recent" data-index="{{index}}" bindtap="applySavedFilter">使用</view>
      </view>
    </view>
    <view class="filter-actions">
      <view class="btn-ghost" bindtap="resetFilters">重置</view>
      <view class="btn-primary" bindtap="applyFilters">应用</view>
    </view>
  </view>
</view>
