page {
  height: 100%;
  background: #f5f6f7;
}

.market-page {
  box-sizing: border-box;
  background: #f5f6f7;
}

.market-page--map {
  position: relative;
  height: 100%;
  overflow: hidden;
}

.market-page--list {
  min-height: 100%;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

/* —— Top search row —— */
.top-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  width: 100%;
  box-sizing: border-box;
}

.search-bar {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  height: 72rpx;
  padding-left: 20rpx;
  padding-right: 8rpx;
  background: #fff;
  border-radius: 36rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.search-icon {
  flex-shrink: 0;
  width: 36rpx;
  color: #8c9591;
  font-size: 30rpx;
  line-height: 72rpx;
  text-align: center;
}

.search-input {
  flex: 1;
  width: 0;
  min-width: 0;
  height: 72rpx;
  min-height: 72rpx;
  margin: 0;
  padding: 0 12rpx;
  border: none !important;
  background: transparent !important;
  color: #1a1a1a;
  font-size: 28rpx;
  line-height: 72rpx;
  box-shadow: none !important;
}

.search-ph {
  color: #b0b8b4;
  font-size: 28rpx;
}

.search-clear {
  flex-shrink: 0;
  padding: 0 12rpx;
  color: #8c9591;
  font-size: 24rpx;
  line-height: 72rpx;
}

.search-submit {
  flex-shrink: 0;
  height: 56rpx;
  padding: 0 22rpx;
  margin-left: 4rpx;
  border-radius: 28rpx;
  background: #0c7a63;
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 56rpx;
}

.filter-btn {
  flex-shrink: 0;
  height: 72rpx;
  min-width: 108rpx;
  padding: 0 22rpx;
  border-radius: 36rpx;
  background: #fff;
  color: #333;
  font-size: 26rpx;
  font-weight: 500;
  line-height: 72rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.filter-btn.on {
  background: #0c7a63;
  color: #fff;
}

/* —— Result bar —— */
.result-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 16rpx;
  padding: 0 4rpx;
  color: #8c9591;
  font-size: 22rpx;
}

.result-bar--float {
  margin-top: 12rpx;
  padding: 12rpx 18rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.result-count {
  color: #0c7a63;
  font-weight: 600;
}

.result-filters {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.result-save {
  color: #0c7a63;
  font-weight: 600;
}

/* —— List page —— */
.market-page--list .top-bar {
  padding: 16rpx 24rpx 0;
}

.market-page--list .result-bar {
  padding: 0 28rpx;
}

.list-view {
  padding: 12rpx 24rpx 0;
}

.job-card {
  display: flex;
  width: 100%;
  box-sizing: border-box;
  margin-top: 16rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
}

.job-cover {
  flex-shrink: 0;
  width: 148rpx;
  height: 148rpx;
  margin-right: 22rpx;
  border-radius: 14rpx;
  background: #e8efec;
}

.job-cover--placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #0c7a63;
  font-size: 40rpx;
  font-weight: 700;
  background: linear-gradient(145deg, #e7f5f0, #d5ebe3);
}

.job-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.job-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.job-title {
  flex: 1;
  min-width: 0;
  color: #1a1a1a;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.job-pay {
  flex-shrink: 0;
  color: #e85d04;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.35;
}

.job-loc {
  margin-top: 10rpx;
  color: #8c9591;
  font-size: 24rpx;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.job-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-top: 14rpx;
}

.job-tag {
  max-width: 60%;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background: #eef8f4;
  color: #0c7a63;
  font-size: 20rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.job-time {
  color: #b0b8b4;
  font-size: 22rpx;
}

.state-tip {
  padding: 32rpx 0;
  color: #b0b8b4;
  font-size: 24rpx;
  text-align: center;
}

.state-empty {
  margin-top: 80rpx;
  padding: 48rpx 32rpx;
  text-align: center;
}

.state-empty-title {
  display: block;
  color: #5c6b65;
  font-size: 30rpx;
  font-weight: 600;
}

.state-empty-desc {
  display: block;
  margin-top: 12rpx;
  color: #b0b8b4;
  font-size: 24rpx;
}

/* —— Map —— */
.map-shell {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: #dfe8e4;
}

.market-map {
  width: 100%;
  height: 100%;
}

.map-toast {
  position: absolute;
  top: 140rpx;
  left: 50%;
  z-index: 2;
  max-width: 70%;
  padding: 14rpx 28rpx;
  transform: translateX(-50%);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.96);
  color: #5c6b65;
  font-size: 24rpx;
  text-align: center;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.08);
}

.map-chrome {
  position: absolute;
  top: 0;
  right: 0;
  left: 0;
  z-index: 6;
  padding: 16rpx 24rpx 0;
  pointer-events: none;
}

.map-chrome .top-bar,
.map-chrome .result-bar,
.map-chrome .notice-bar,
.map-chrome .error-bar {
  pointer-events: auto;
}

.notice-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 12rpx;
  padding: 16rpx 20rpx;
  border-radius: 14rpx;
  background: rgba(255, 247, 232, 0.98);
  color: #9a6412;
  font-size: 23rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.notice-text {
  flex: 1;
}

.notice-action {
  flex-shrink: 0;
  font-weight: 700;
}

.error-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin: 16rpx 24rpx 0;
  padding: 16rpx 20rpx;
  border-radius: 14rpx;
  background: #fff1ef;
  color: #8f322c;
  font-size: 24rpx;
}

.error-bar--float {
  margin: 12rpx 0 0;
  background: rgba(255, 241, 239, 0.98);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.error-retry {
  flex-shrink: 0;
  color: #0c7a63;
  font-weight: 700;
}

/* —— Filter sheet —— */
.filter-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 40;
  background: rgba(0, 0, 0, 0.4);
}

.filter-sheet {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 41;
  max-height: 80vh;
  overflow-y: auto;
  padding: 28rpx 32rpx calc(28rpx + env(safe-area-inset-bottom));
  border-radius: 28rpx 28rpx 0 0;
  background: #fff;
}

.filter-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.filter-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.filter-close {
  color: #8c9591;
  font-size: 26rpx;
}

.f-label {
  display: block;
  margin-top: 20rpx;
  color: #5c6b65;
  font-size: 24rpx;
}

.f-label input,
.f-picker {
  width: 100%;
  height: 80rpx;
  min-height: 80rpx;
  margin-top: 10rpx;
  padding: 0 22rpx;
  border: 1rpx solid #e8ecea;
  border-radius: 14rpx;
  background: #f7f8f8;
  color: #1a1a1a;
  font-size: 28rpx;
  line-height: 80rpx;
  box-sizing: border-box;
}

.saved-block {
  margin-top: 24rpx;
}

.saved-title {
  display: block;
  margin-bottom: 12rpx;
  color: #1a1a1a;
  font-size: 26rpx;
  font-weight: 700;
}

.saved-row {
  display: flex;
  gap: 12rpx;
  margin-top: 10rpx;
}

.saved-btn {
  flex: 1;
  height: 64rpx;
  border-radius: 12rpx;
  background: #f4f6f5;
  color: #5c6b65;
  font-size: 24rpx;
  line-height: 64rpx;
  text-align: center;
}

.filter-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 32rpx;
}

.btn-ghost,
.btn-primary {
  flex: 1;
  height: 88rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 88rpx;
  text-align: center;
}

.btn-ghost {
  background: #f4f6f5;
  color: #5c6b65;
}

.btn-primary {
  background: #0c7a63;
  color: #fff;
}
