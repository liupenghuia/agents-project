.market-page { padding: 34rpx 28rpx 150rpx; }
.market-header { display: flex; align-items: flex-start; justify-content: space-between; gap: 24rpx; }
.market-header .title { font-size: 48rpx; }
.favorite-button { margin: 8rpx 0 0; padding: 0 28rpx; height: 68rpx; border: 1rpx solid #cbded7; background: #fff; color: #0d6f5c; font-size: 25rpx; line-height: 68rpx; }
.mode-switch { display: grid; grid-template-columns: 1fr 1fr; margin-top: 28rpx; padding: 6rpx; background: #e8eeec; border-radius: 6rpx; }
.mode-button { margin: 0; height: 68rpx; padding: 0; border-radius: 4rpx; background: transparent; color: #61706b; font-size: 26rpx; line-height: 68rpx; }
.mode-button.active { background: #fff; color: #17332d; font-weight: 700; box-shadow: 0 2rpx 8rpx #16352a12; }
.search-row { display: flex; gap: 12rpx; margin: 18rpx 0; }
.search-row input { flex: 1; height: 76rpx; padding: 0 22rpx; border: 1rpx solid #d5dfdb; background: #fff; line-height: 76rpx; }
.search-row button, .detail-head button, .detail-actions button, .contact-row button, .retry-button, .location-notice button { margin: 0; padding: 0 24rpx; height: 76rpx; background: #fff; color: #0d6f5c; font-size: 25rpx; line-height: 76rpx; }
.filter-trigger { width: 100%; margin: 0 0 18rpx; height: 68rpx; border: 1rpx solid #d5dfdb; background: #fff; color: #0d6f5c; font-size: 25rpx; line-height: 68rpx; text-align: left; }
.filter-summary { display: flex; flex-wrap: wrap; align-items: center; gap: 12rpx 18rpx; margin: 0 0 16rpx; color: #52615c; font-size: 23rpx; }
.filter-summary .small-button { margin: 0; padding: 0 18rpx; height: 56rpx; line-height: 56rpx; font-size: 22rpx; background: #eef6f3; color: #0d6f5c; }
.saved-block { margin-top: 20rpx; }
.saved-block .section-title { display: block; margin-bottom: 10rpx; color: #17332d; font-size: 26rpx; font-weight: 700; }
.saved-row { display: flex; gap: 12rpx; margin-top: 10rpx; }
.saved-row button { margin: 0; flex: 1; height: 60rpx; line-height: 60rpx; font-size: 22rpx; background: #f4f7f6; color: #52615c; }
.filter-sheet { position: fixed; right: 0; bottom: 0; left: 0; z-index: 20; padding: 32rpx 32rpx calc(32rpx + env(safe-area-inset-bottom)); border-radius: 16rpx 16rpx 0 0; background: #fff; box-shadow: 0 -12rpx 48rpx #17332d2b; }
.filter-head, .filter-actions { display: flex; align-items: center; justify-content: space-between; gap: 16rpx; }
.filter-head { margin-bottom: 20rpx; font-size: 32rpx; font-weight: 700; }
.filter-head button, .filter-actions button { margin: 0; padding: 0 22rpx; height: 68rpx; background: #f4f7f6; color: #52615c; font-size: 24rpx; line-height: 68rpx; }
.filter-sheet label { display: block; margin-top: 18rpx; color: #52615c; font-size: 24rpx; }
.filter-sheet input, .filter-picker { width: 100%; height: 72rpx; margin-top: 10rpx; padding: 0 20rpx; border: 1rpx solid #d5dfdb; background: #f8faf9; line-height: 72rpx; }
.filter-actions { margin-top: 28rpx; }
.filter-actions button { flex: 1; }
.filter-actions .apply-filter { background: #0d7c66; color: #fff; }
.location-notice { display: flex; align-items: center; justify-content: space-between; gap: 16rpx; margin-bottom: 14rpx; padding: 16rpx 20rpx; background: #fff7e6; color: #73561e; font-size: 23rpx; }
.location-notice text { flex: 1; }
.location-notice button { height: 58rpx; padding: 0 18rpx; line-height: 58rpx; }
.map-shell { position: relative; height: 920rpx; min-height: 560rpx; overflow: hidden; border: 1rpx solid #d2ded9; background: #e8efec; }
.market-map { width: 100%; height: 100%; }
.map-state { position: absolute; top: 24rpx; left: 50%; max-width: 70%; padding: 14rpx 24rpx; transform: translateX(-50%); background: #ffffffee; color: #52615c; font-size: 23rpx; text-align: center; }
.map-legend { position: absolute; right: 20rpx; bottom: 20rpx; left: 20rpx; display: flex; align-items: center; gap: 12rpx; padding: 16rpx 20rpx; background: #17332de8; color: #fff; font-size: 22rpx; }
.legend-dot { width: 18rpx; height: 18rpx; border-radius: 50%; background: #42b896; }
.list-view { min-height: 600rpx; }
.action-card { width: 100%; margin-top: 16rpx; padding: 26rpx 28rpx; border: 1rpx solid #d9e6e2; border-radius: 6rpx; background: #fff; text-align: left; }
.market-card { display: flex; align-items: stretch; gap: 22rpx; min-height: 160rpx; }
.card-cover { flex: none; width: 164rpx; height: 132rpx; background: #e8efec; }
.card-copy { min-width: 0; flex: 1; }
.action-title { display: block; margin-bottom: 8rpx; color: #17332d; font-size: 31rpx; font-weight: 700; }
.published, .detail-line { display: block; margin-top: 12rpx; color: #73807c; font-size: 23rpx; }
.match-line { display: block; margin-top: 10rpx; color: #0d7c66; font-size: 22rpx; }
.list-progress { padding: 28rpx 0 8rpx; color: #7b8883; font-size: 23rpx; text-align: center; }
.empty { margin-top: 24rpx; }
.error { display: flex; align-items: center; justify-content: space-between; gap: 20rpx; }
.retry-button { flex: none; height: 58rpx; line-height: 58rpx; }
.detail-backdrop { position: fixed; inset: 0; z-index: 9; background: #101b1870; }
.detail { position: fixed; right: 24rpx; bottom: 24rpx; left: 24rpx; z-index: 10; max-height: 72vh; overflow-y: auto; box-shadow: 0 12rpx 40rpx #0003; }
.detail-head, .detail-actions, .contact-row { display: flex; align-items: center; justify-content: space-between; gap: 16rpx; }
.detail-eyebrow, .contact-label { display: block; color: #75817d; font-size: 22rpx; }
.detail-title { display: block; margin-top: 6rpx; color: #17212b; font-size: 36rpx; font-weight: 700; }
.detail-images { width: 100%; margin-top: 22rpx; white-space: nowrap; }
.detail-images image { display: inline-block; width: 250rpx; height: 180rpx; margin-right: 12rpx; background: #e8efec; }
.contact-row { margin-top: 26rpx; padding: 22rpx; background: #edf5f2; }
.contact-phone { display: block; margin-top: 6rpx; color: #17332d; font-size: 30rpx; font-weight: 700; }
.detail-actions { justify-content: flex-start; margin-top: 24rpx; }
.detail-actions .primary-action { background: #0d7c66; color: #fff; }
.tabbar { position: fixed; right: 0; bottom: 0; left: 0; z-index: 12; display: flex; padding: 12rpx 28rpx calc(12rpx + env(safe-area-inset-bottom)); border-top: 1rpx solid #dce6e2; background: #fffffff5; box-shadow: 0 -8rpx 24rpx #17332d0d; }
.tab-item { flex: 1; height: 76rpx; margin: 0; padding: 0; background: transparent; color: #73807c; font-size: 25rpx; line-height: 76rpx; }
.tab-item.active, .tab-item:first-child { color: #0d7c66; font-weight: 700; }
