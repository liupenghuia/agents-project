.search-row { display:flex; gap:12rpx; margin:24rpx 0; }.search-row input { flex:1; background:#fff; border:1rpx solid #d9e6e2; padding:18rpx; }.search-row button,.detail-head button,.detail-actions button { margin:0; padding:0 22rpx; line-height:68rpx; font-size:24rpx; }.published,.detail-line { display:block; margin-top:12rpx; color:#73807c; font-size:22rpx; }.empty { margin-top:24rpx; }.detail { position:fixed; left:24rpx; right:24rpx; bottom:24rpx; z-index:10; box-shadow:0 8rpx 28rpx #0002; }.detail-head,.detail-actions { display:flex; justify-content:space-between; align-items:center; gap:16rpx; }.detail-actions { justify-content:flex-start; margin-top:24rpx; }
