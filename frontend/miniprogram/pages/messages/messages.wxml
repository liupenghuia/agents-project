<view class="page">
  <view class="eyebrow">站内沟通</view>
  <text class="title">消息</text>
  <view class="toolbar">
    <button bindtap="openApplications">投递</button>
    <button bindtap="openInterviews">面试</button>
    <button bindtap="openMyCenter">我的</button>
  </view>
  <view wx:if="{{loading}}" class="loading">正在读取会话...</view>
  <view wx:elif="{{!items.length && !error}}" class="panel empty">暂无消息，可从详情页发起沟通</view>
  <button wx:for="{{items}}" wx:key="id" class="action-card" data-id="{{item.id}}" bindtap="open">
    <view class="row"><text class="action-title">{{item.peer.displayName}}</text><text wx:if="{{item.unreadCount}}" class="badge">{{item.unreadCount}}</text></view>
    <text class="muted">{{item.lastMessage.body || '暂无消息'}}</text>
    <text class="published">{{item.status === 'active' ? '进行中' : item.status === 'ended' ? '已结束' : '已阻止'}}</text>
  </button>
  <view wx:if="{{error}}" class="error"><text>{{error}}</text><button class="button-secondary" bindtap="retry">重试</button></view>
</view>
