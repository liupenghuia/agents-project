<view class="me-page">
  <view wx:if="{{loading}}" class="me-loading">正在读取...</view>

  <block wx:elif="{{!error}}">
    <view class="me-header">
      <view class="me-avatar">{{role === 'recruiter' ? '招' : '应'}}</view>
      <view class="me-header-copy">
        <text class="me-name">{{role === 'recruiter' ? '招人方' : '应聘方'}}</text>
        <text class="me-sub">{{roleHint}}</text>
      </view>
      <view wx:if="{{canSwitchRole}}" class="me-switch" bindtap="switchRole">切换身份</view>
    </view>

    <view class="me-group">
      <view class="me-group-title">身份</view>
      <view class="me-cell-card">
        <view wx:if="{{!identities.length}}" class="me-empty">暂无身份，请先完成注册</view>
        <view
          wx:for="{{identities}}"
          wx:key="id"
          class="me-row me-identity {{item.role === role ? 'is-active' : ''}}"
          data-role="{{item.role}}"
          data-status="{{item.reviewStatus}}"
          bindtap="onIdentityTap"
        >
          <view class="me-identity-main">
            <text class="me-row-label">{{item.role === 'applicant' ? '应聘方' : '招人方'}}</text>
            <text wx:if="{{item.role === role && item.reviewStatus === 'approved'}}" class="me-current">当前使用</text>
          </view>
          <text class="me-status me-status-{{item.reviewStatus}}">{{status[item.reviewStatus] || item.reviewStatus}}</text>
        </view>
        <view
          wx:if="{{identities.length === 1}}"
          class="me-menu me-menu--last"
          bindtap="createOtherRole"
        >
          <view class="me-menu-main">
            <text class="me-menu-title">开通另一身份</text>
            <text class="me-menu-desc">招人与应聘可同时拥有，互不影响</text>
          </view>
          <text class="me-arrow">›</text>
        </view>
      </view>
    </view>

    <view class="me-group">
      <view class="me-group-title">协作</view>
      <view class="me-cell-card">
        <view class="me-menu" bindtap="openMessages">
          <view class="me-menu-main">
            <text class="me-menu-title">消息</text>
            <text class="me-menu-desc">站内沟通与未读会话</text>
          </view>
          <text class="me-arrow">›</text>
        </view>
        <view class="me-menu" bindtap="openApplications">
          <view class="me-menu-main">
            <text class="me-menu-title">{{role === 'recruiter' ? '收到的投递' : '我的投递'}}</text>
            <text class="me-menu-desc">{{role === 'recruiter' ? '处理求职意向' : '查看投递进度'}}</text>
          </view>
          <text class="me-arrow">›</text>
        </view>
        <view class="me-menu me-menu--last" bindtap="openInterviews">
          <view class="me-menu-main">
            <text class="me-menu-title">面试安排</text>
            <text class="me-menu-desc">邀请、接受与取消</text>
          </view>
          <text class="me-arrow">›</text>
        </view>
      </view>
    </view>

    <view class="me-group">
      <view class="me-group-title">个人</view>
      <view class="me-cell-card">
        <view class="me-menu" bindtap="openProfile">
          <view class="me-menu-main">
            <text class="me-menu-title">个人资料</text>
            <text class="me-menu-desc">维护当前身份信息</text>
          </view>
          <text class="me-arrow">›</text>
        </view>
        <view class="me-menu me-menu--last" bindtap="openFavorites">
          <view class="me-menu-main">
            <text class="me-menu-title">我的收藏</text>
            <text class="me-menu-desc">已收藏的市场信息</text>
          </view>
          <text class="me-arrow">›</text>
        </view>
      </view>
    </view>

    <view class="me-group">
      <view class="me-group-head">
        <text class="me-group-title">{{role === 'recruiter' ? '我的招聘' : '我的求职信息'}}</text>
        <text class="me-link" bindtap="openCreatePublication">{{role === 'recruiter' ? '去发布' : '去完善'}}</text>
      </view>
      <view class="me-cell-card">
        <view wx:if="{{!publications.length}}" class="me-empty">
          {{role === 'recruiter' ? '还没有招聘信息，发布后会出现在地图与列表' : '完善求职信息后，招人方可在市场中发现你'}}
        </view>
        <view
          wx:for="{{publications}}"
          wx:key="publicationId"
          class="me-pub {{index === publications.length - 1 ? 'me-pub--last' : ''}}"
          data-id="{{role === 'recruiter' ? item.id : ''}}"
          bindtap="openPublication"
        >
          <view class="me-pub-main">
            <text class="me-pub-title">{{item.jobType || item.jobTypeName}}</text>
            <text class="me-pub-meta">{{item.salaryRange || item.expectedSalary}} · {{item.publishedAt || '未发布时间'}}</text>
            <text wx:if="{{item.moderationReason}}" class="me-pub-reason">{{item.moderationReason}}</text>
          </view>
          <text class="me-status">{{item.statusLabel}}</text>
        </view>
      </view>
    </view>

    <view class="me-group">
      <view class="me-group-title">安全</view>
      <view class="me-cell-card">
        <view wx:if="{{!blocks.length}}" class="me-empty">暂无拉黑对象</view>
        <view wx:for="{{blocks}}" wx:key="blockId" class="me-row">
          <view class="me-block-copy">
            <text class="me-row-label">{{item.displayName}}</text>
            <text class="me-menu-desc">{{item.role === 'applicant' ? '应聘方' : '招人方'}}</text>
          </view>
          <view class="me-unblock" data-id="{{item.blockId}}" catchtap="unblock">取消拉黑</view>
        </view>
      </view>
    </view>

    <view class="me-group">
      <view class="me-cell-card me-legal">
        <text class="me-legal-copy">地图仅展示区域级位置，不公开楼栋级详细地址。联系方式仅在详情页按权限展示。</text>
        <view class="me-legal-links">
          <text bindtap="openPrivacy">隐私政策</text>
          <text class="me-dot">·</text>
          <text bindtap="openAgreement">用户协议</text>
        </view>
      </view>
    </view>
  </block>

  <view wx:if="{{error}}" class="me-error">
    <text>{{error}}</text>
    <view class="me-retry" bindtap="retry">重试</view>
  </view>
</view>
