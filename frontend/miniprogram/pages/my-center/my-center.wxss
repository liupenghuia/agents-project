.page { padding-bottom: 48rpx; }
.section-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8rpx; }
.link { color: #0d7c66; font-size: 24rpx; }
.identity-row { display:flex; justify-content:space-between; align-items:center; padding:22rpx 0; border-bottom:1rpx solid #edf0f1; }
.identity-row:last-child { border-bottom:0; }
.small-button { width:auto; min-width:150rpx; height:64rpx; margin:0; padding:0 20rpx; background:#edf5f2; color:#0d7c66; font-size:24rpx; line-height:64rpx; }
.action-card { width:100%; margin-top:24rpx; padding:28rpx; text-align:left; background:#fff; border:1rpx solid #e3e7e9; border-radius:8rpx; }
.action-title { display:block; color:#0d7c66; font-size:30rpx; font-weight:700; }
.publication-row { width: 100%; display: flex; justify-content: space-between; align-items: flex-start; gap: 16rpx; margin-top: 16rpx; padding: 20rpx 0; text-align: left; background: transparent; border: 0; border-top: 1rpx solid #edf0f1; border-radius: 0; }
.publication-row:first-of-type { border-top: 0; }
.publication-title { display: block; color: #17332d; font-size: 28rpx; font-weight: 700; }
.publication-reason { display: block; margin-top: 8rpx; color: #b45309; font-size: 22rpx; }
.publication-state { flex-shrink: 0; color: #0d7c66; font-size: 22rpx; font-weight: 700; }
.legal-links { display: flex; gap: 32rpx; margin-top: 24rpx; color: #0d7c66; font-size: 24rpx; }

