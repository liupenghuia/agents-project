.form { padding: 8rpx 32rpx 32rpx; }
.form label { display: block; padding-top: 26rpx; color: #45515a; font-size: 25rpx; }
.form input, .form textarea { width: 100%; min-height: 80rpx; margin-top: 12rpx; padding: 0 18rpx; border: 1rpx solid #e3e7e9; background: #f7f8fa; line-height: 80rpx; }
.form textarea { min-height: 140rpx; padding-top: 18rpx; line-height: 1.5; }
.success { margin-top: 24rpx; padding: 24rpx; background: #e9f4f0; color: #187049; }
