.form {
  padding: 12rpx 28rpx 32rpx;
}

.form label {
  display: block;
  padding-top: 24rpx;
  color: var(--color-text-secondary);
  font-size: 24rpx;
  font-weight: 500;
}

.form input,
.form textarea {
  width: 100%;
  min-height: 88rpx;
  margin-top: 12rpx;
  padding: 0 22rpx;
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-md);
  background: #f7faf9;
  line-height: 88rpx;
}

.form textarea {
  min-height: 140rpx;
  padding: 20rpx 22rpx;
  line-height: 1.5;
}

.success {
  margin-top: 24rpx;
  padding: 24rpx 28rpx;
  border-radius: var(--radius-md);
  background: var(--color-primary-soft);
  color: #187049;
  font-size: 26rpx;
}
