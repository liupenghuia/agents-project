.form {
  margin-top: 28rpx;
  padding: 12rpx 28rpx 32rpx;
}

.label {
  display: block;
  padding-top: 24rpx;
  color: var(--color-text-secondary);
  font-size: 24rpx;
  font-weight: 500;
}

.label > text {
  color: var(--color-danger);
}

input,
.location-button {
  width: 100%;
  margin-top: 12rpx;
  min-height: 88rpx;
  padding: 0 22rpx;
  background: #f7faf9;
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-md);
  color: var(--color-text);
  line-height: 88rpx;
  text-align: left;
}

.location-button {
  color: var(--color-primary-deep);
  font-weight: 600;
  background: var(--color-primary-soft);
  border-color: #cfe3db;
}

.success {
  margin-top: 24rpx;
  padding: 24rpx 28rpx;
  border-radius: var(--radius-md);
  background: var(--color-primary-soft);
  color: #187049;
}
