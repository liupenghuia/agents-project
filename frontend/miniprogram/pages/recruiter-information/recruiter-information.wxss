.form { margin-top: 36rpx; padding: 8rpx 32rpx 32rpx; }
.label { display: block; padding-top: 28rpx; color: #45515a; font-size: 25rpx; }
.label > text { color: #d94f45; }
input, .location-button { width: 100%; margin-top: 14rpx; min-height: 84rpx; padding: 0 20rpx; background: #f7f8fa; border: 1rpx solid #e3e7e9; border-radius: 4rpx; color: #17212b; line-height: 84rpx; text-align: left; }
.location-button { color: #0d7c66; }
.success { margin-top: 24rpx; padding: 24rpx; background: #e9f4f0; color: #187049; }
