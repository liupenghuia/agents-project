.form {
  margin-top: 28rpx;
  padding: 12rpx 28rpx 32rpx;
}

.label {
  display: block;
  padding-top: 24rpx;
  color: var(--color-text-secondary);
  font-size: 24rpx;
  font-weight: 500;
}

.label > text {
  color: var(--color-danger);
}

.label > .optional-label {
  color: var(--color-text-muted);
}

input,
.location-button,
.upload-button {
  width: 100%;
  margin-top: 12rpx;
  min-height: 88rpx;
  padding: 0 22rpx;
  background: #f7faf9;
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-md);
  color: var(--color-text);
  line-height: 88rpx;
  text-align: left;
}

.location-button,
.upload-button {
  color: var(--color-primary-deep);
  font-weight: 600;
  background: var(--color-primary-soft);
  border-color: #cfe3db;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 18rpx;
}

.image-item {
  position: relative;
  width: 190rpx;
  height: 190rpx;
  overflow: hidden;
  background: #edf5f2;
  border-radius: var(--radius-md);
}

.image-item image {
  width: 100%;
  height: 100%;
}

.image-item button {
  position: absolute;
  right: 8rpx;
  bottom: 8rpx;
  padding: 0 14rpx;
  height: 44rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.65);
  color: #fff;
  font-size: 20rpx;
  line-height: 44rpx;
}

.existing {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx;
  color: var(--color-primary);
  text-align: center;
}

.existing text {
  font-size: 23rpx;
}

.success {
  margin-top: 24rpx;
  padding: 24rpx 28rpx;
  border-radius: var(--radius-md);
  background: var(--color-primary-soft);
  color: #187049;
}

.publication-status {
  margin-top: 20rpx;
  padding: 20rpx 24rpx;
  border-radius: var(--radius-md);
  font-size: 24rpx;
}

.publication-status text {
  display: block;
}

.publication-status .status-title {
  margin-bottom: 6rpx;
  font-weight: 700;
}

.publication-status .moderation-reason {
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid currentColor;
}

.status-published {
  background: #e9f4f0;
  color: #187049;
}

.status-disabled {
  background: #fff3e8;
  color: #9a552b;
}

.status-pending_review {
  background: #fff8db;
  color: #886813;
}

.status-changes_requested {
  background: #fff0ee;
  color: #a53f36;
}

.danger-action {
  width: 100%;
  margin-top: 16rpx;
  height: 88rpx;
  border: 1rpx solid #e8c5bf;
  border-radius: var(--radius-md);
  background: #fff;
  color: #a53f36;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 88rpx;
}
