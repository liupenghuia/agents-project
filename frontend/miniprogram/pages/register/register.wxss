.form { margin-top: 36rpx; padding: 8rpx 32rpx 32rpx; }
.label { display: block; padding-top: 28rpx; color: #45515a; font-size: 25rpx; }
.label > text { color: #d94f45; }
input, textarea, .picker { width: 100%; margin-top: 14rpx; padding: 0 20rpx; min-height: 84rpx; background: #f7f8fa; border: 1rpx solid #e3e7e9; border-radius: 4rpx; color: #17212b; line-height: 84rpx; }
textarea { padding-top: 18rpx; min-height: 120rpx; line-height: 1.5; }
.picker { color: #8a949b; }
.phone-button { margin-top: 20rpx; padding: 0; height: 76rpx; background: #edf5f2; color: #0d7c66; font-size: 25rpx; line-height: 76rpx; }
.agreement { display: flex; align-items: center; flex-wrap: wrap; gap: 8rpx; margin-top: 28rpx; color: #68747d; font-size: 23rpx; }
.agreement checkbox { transform: scale(.8); }
.footnote { display: block; margin-top: 24rpx; color: #8a949b; font-size: 22rpx; line-height: 1.5; text-align: center; }
