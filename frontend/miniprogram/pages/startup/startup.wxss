.startup-page { display: flex; min-height: 100vh; flex-direction: column; align-items: center; justify-content: center; padding: 64rpx; background: #f7f8fa; text-align: center; }
.startup-mark { color: #0d7c66; font-size: 76rpx; font-weight: 800; letter-spacing: 4rpx; }
